{
  "schema_version": "1",
  "tool": "propose_skeleton",
  "args": {
    "phases": [
      {
        "id": "P1",
        "title": "build the page",
        "exit_criterion": [{ "cmd": "npm run build", "expect_exit": 0 }],
        "epoch_budget": 3
      },
      {
        "id": "P2",
        "title": "taste-review the rendered UI",
        "exit_criterion": [
          { "cmd": "node scripts/screenshot.js ui/screen.png", "expect_exit": 0 },
          {
            "vision_review": {
              "screenshot": "ui/screen.png",
              "criteria": "balanced layout, aligned controls, readable contrast, no overflow"
            }
          }
        ],
        "epoch_budget": 2
      }
    ]
  }
}
