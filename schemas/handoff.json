{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "grindstone/handoff/v1",
  "title": "Worker handoff (written by the worker as handoff.json in its own CWD; the disk file is the gate, stdout is never parsed). Total serialized size capped at 8192 UTF-8 bytes by the generated validator.",
  "type": "object",
  "required": ["schema_version", "task_id", "status", "resulting_state", "checks", "occupancy"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "1" },
    "task_id": {
      "type": "string",
      "pattern": "^P[1-9][0-9]?/E[1-9][0-9]?/T[1-8]$",
      "description": "Fully-qualified phase/epoch/task key."
    },
    "status": { "enum": ["DONE", "FAILED", "PARTIAL"] },
    "what_changed": {
      "type": "array",
      "maxItems": 16,
      "default": [],
      "items": {
        "type": "object",
        "required": ["kind", "ref"],
        "additionalProperties": false,
        "properties": {
          "kind": { "enum": ["file", "interface", "artifact"] },
          "ref": { "type": "string", "minLength": 1, "maxLength": 256 }
        }
      }
    },
    "resulting_state": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1500,
      "description": "Compact state summary for the planner. References, not payloads."
    },
    "downstream_needs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9][a-zA-Z0-9._/-]{0,127}$"
      },
      "maxItems": 8,
      "default": [],
      "description": "Log keys downstream tasks will need."
    },
    "not_done": {
      "type": "array",
      "items": { "type": "string", "maxLength": 256 },
      "maxItems": 8,
      "default": []
    },
    "citations": {
      "type": "array",
      "maxItems": 12,
      "default": [],
      "description": "Grounding targets: Grindstone deterministically spot-checks a sample. Research/review handoffs require >= 1 (semantic validator rule). A hallucinated citation fails the handoff.",
      "items": {
        "type": "object",
        "required": ["file"],
        "additionalProperties": false,
        "properties": {
          "file": { "type": "string", "minLength": 1, "maxLength": 256 },
          "line": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "checks": {
      "type": "array",
      "maxItems": 8,
      "description": "Echo of the task's done_when results as run by the worker (the planner's checks, max 6, plus the core-appended validator and implement-mode review gates). Grindstone re-runs them on return; this field is the worker's claim, the re-run is the gate.",
      "items": {
        "type": "object",
        "required": ["check", "exit_code"],
        "additionalProperties": false,
        "properties": {
          "check": { "type": "string", "maxLength": 512 },
          "exit_code": { "type": "integer" }
        }
      }
    },
    "occupancy": {
      "type": "object",
      "required": ["compacted", "subagent_splits"],
      "additionalProperties": false,
      "description": "Post-hoc context telemetry behind the uniform interface. Replaces any live occupancy sensor; feeds re-decomposition granularity.",
      "properties": {
        "compacted": { "type": "boolean" },
        "subagent_splits": { "type": "integer", "minimum": 0 },
        "peak_context_tokens": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
