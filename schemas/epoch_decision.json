{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "grindstone/epoch_decision/v1",
  "title": "Grindstone planner decision (one boundary): propose an epoch, or end the run. Pydantic (grindstone.contracts.models) is the source of truth; this schema mirrors it.",
  "oneOf": [
    { "$ref": "#/$defs/epoch_decision" },
    { "$ref": "#/$defs/end_decision" }
  ],
  "$defs": {
    "log_key": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][a-zA-Z0-9._/-]{0,127}$",
      "description": "A relative path under the run dir's keyed log."
    },
    "epoch_decision": {
      "type": "object",
      "required": ["kind", "epoch"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "epoch" },
        "epoch": { "$ref": "#/$defs/epoch" },
        "pending": {
          "type": "array",
          "maxItems": 16,
          "default": [],
          "description": "This epoch's ADDITIONS to the persisted work backlog: short prose descriptions of deferred FUTURE work the close-out folds into the baton's ## Pending section (the next plan schedules a subset from it). May exceed the tasks scheduled this epoch.",
          "items": { "type": "string", "minLength": 1, "maxLength": 512 }
        }
      }
    },
    "end_decision": {
      "type": "object",
      "required": ["kind", "summary"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "end" },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4096,
          "description": "The phase handoff / pending-summary: the resume seed that lets the work continue as the next appendable run (a clean end, or a satisfied done)."
        }
      }
    },
    "epoch": {
      "type": "object",
      "required": ["title", "tasks"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string", "minLength": 1, "maxLength": 120 },
        "tasks": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "items": { "$ref": "#/$defs/task" }
        },
        "setup": {
          "type": "array",
          "maxItems": 8,
          "default": [],
          "description": "Planner-declared (trusted-tier) host setup/install commands the orchestrator runs before the tasks. The untrusted worker never improvises host mutations.",
          "items": { "type": "string", "minLength": 1, "maxLength": 512 }
        }
      }
    },
    "task": {
      "type": "object",
      "required": ["id", "mode", "goal"],
      "additionalProperties": false,
      "description": "One fanned-out unit. An implement task owns files; a research/review/artifact task produces one artifact at a log key (the implement-vs-artifact shape rule is enforced by the Pydantic model).",
      "properties": {
        "id": { "type": "string", "pattern": "^T[1-8]$" },
        "mode": { "enum": ["implement", "research", "review", "artifact"] },
        "goal": { "type": "string", "minLength": 1, "maxLength": 2048 },
        "tier": { "enum": ["local", "senior"], "default": "local" },
        "file_ownership": {
          "type": "array",
          "maxItems": 32,
          "default": [],
          "items": { "type": "string", "minLength": 1, "maxLength": 256 }
        },
        "artifact_out": { "$ref": "#/$defs/log_key" },
        "skills": {
          "type": "array",
          "maxItems": 6,
          "default": [],
          "items": { "type": "string", "minLength": 1, "maxLength": 64 }
        },
        "inputs": {
          "type": "array",
          "maxItems": 12,
          "default": [],
          "items": { "$ref": "#/$defs/log_key" }
        }
      }
    }
  }
}
